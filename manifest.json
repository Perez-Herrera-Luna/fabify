{
  "manifest_version": 3,
  "name": "Fabify",
  "version": "1.2",

  "description": "Fabify is a browser extension for replacing typed symbols with corresponding icons on the official Flesh and Blood website (fabtcg.com).",

  "icons": {
    "16": "icons/fabify-icon-16.png",
    "32": "icons/fabify-icon-32.png",
    "48": "icons/fabify-icon-48.png",
    "128": "icons/fabify-icon-128.png"
  },

  "browser_specific_settings": {
    "gecko": {
      "id": "@fabify",
      "data_collection_permissions": {
        "required": ["none"]
      }
    }
  },

  "content_scripts": [
    {
      "matches": ["*://*.fabtcg.com/*"],
      "js": ["fabify.js"],
      "run_at": "document_idle"
    }
  ],

  "web_accessible_resources": [
    {
      "resources": ["fab_icons/*.png"],
      "matches": ["*://*.fabtcg.com/*"]
    }
  ]
}